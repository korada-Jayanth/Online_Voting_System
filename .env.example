# Database
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

AUTH_DB_URL=jdbc:mysql://localhost:3306/voting_auth_db
AUTH_DB_USERNAME=root
AUTH_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

ELECTION_DB_URL=jdbc:mysql://localhost:3306/election_db
ELECTION_DB_USERNAME=root
ELECTION_DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

VOTE_DB_URL=jdbc:mysql://localhost:3306/vote_db
