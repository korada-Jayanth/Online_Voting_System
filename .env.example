# Service Discovery
EUREKA_DEFAULT_ZONE=http://localhost:8761/eureka

# JWT (must be 32+ chars for HS256)
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_32_PLUS_CHARS
